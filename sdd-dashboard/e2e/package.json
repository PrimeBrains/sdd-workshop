{
  "name": "sdd-review-ui-e2e",
  "private": true,
  "version": "0.1.0",
  "description": "SDD Review UI E2E (Playwright, 実 sdd-core サーバー + フィクスチャリポジトリ / tasks.md 10.1)",
  "type": "module",
  "scripts": {
    "test:e2e": "playwright test",
    "check:dist": "node --import tsx check-dist-no-external-urls.ts",
    "selftest:dist": "node --import tsx check-dist-no-external-urls.ts --self-test",
    "verify:local": "npm --prefix ../client run build && npm run check:dist",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0"
  }
}
